# Copia este archivo a .env en la raíz del proyecto
#   Windows: copy .env.example .env
#   Linux:   cp .env.example .env

# ─── REQUERIDO ───────────────────────────────────────────────────────────────
# Obtén tu key en https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── OPCIONALES (ya tienen defaults sensatos) ────────────────────────────────

# Modelo de Claude. Haiku = más rápido y barato; Sonnet = más capaz.
CLAUDE_MODEL=claude-haiku-4-5-20251001

# Host/puerto del servidor WebSocket (cambiar si el servidor está en la nube)
SERVER_HOST=127.0.0.1
SERVER_PORT=8000
SERVER_URL=ws://127.0.0.1:8000/ws

# Minutos de inactividad antes de reiniciar el historial de conversación
# (evita que el contexto crezca indefinidamente y suba los costos)
RESET_AFTER_MINUTES=5

# Wake word para filtrar cuando el micrófono está activo
WAKE_WORD=jarvis

# Modelo Whisper STT local: tiny | base | small | medium | large
# base = buen balance calidad/velocidad para español
# small o medium = mejor precisión si base falla con tu acento
STT_MODEL=base

# ─── AFTER EFFECTS (solo si usas el Milestone 6) ─────────────────────────────
# Ajusta al año y versión exacta que tengas instalada
# macOS:
AE_PATH=/Applications/Adobe After Effects 2024/AfterFX.app/Contents/MacOS/AfterFX
# Windows (descomenta y comenta la línea de arriba):
# AE_PATH=C:\Program Files\Adobe\Adobe After Effects 2024\Support Files\AfterFX.exe
